[
  {
    "id": "evt-xishui-rendezvous-1935-02-02",
    "type": "maneuver",
    "title": "逼近叙永",
    "timestamp": "1935-02-02T10:00:00+08:00",
    "duration_hours": 36,
    "location": [105.45, 28.18],
    "participants": ["red-1st-army", "red-3rd-army", "red-5th-army", "red-9th-army", "blue-sichuan-liuxiang"],
    "outcome": "stalemate",
    "description": "1935年2月2日,中央红军各部向叙永方向集结,红一、红三军团进至叙永附近,红五、红九军团在叙永以南护翼。红二师围攻叙永县城未克,与川军刘湘主力在叙永城外形成对峙,未能打通北渡长江的道路。",
    "sources": ["《红军长征史》", "《毛泽东年谱》"]
  },
  {
    "id": "evt-zhaxi-meeting-1935-02-05",
    "type": "meeting",
    "title": "扎西会议(鸡鸣三省会议)",
    "timestamp": "1935-02-05T14:00:00+08:00",
    "duration_hours": 72,
    "location": [105.05, 27.85],
    "participants": ["person-mao-zedong", "person-zhou-enlai", "person-zhangwentian", "person-chenyun", "person-zhude"],
    "outcome": "red-advance",
    "description": "1935年2月5日至8日,中央政治局在云南威信(扎西)地区连续召开会议,即著名的'鸡鸣三省会议'。会议决定由张闻天代替博古在党内负总责,讨论了中央红军的战略方针,毛泽东提出根据敌情变化回师东进,放弃北渡长江的原定计划。",
    "sources": ["《张闻天年谱》", "《中国工农红军长征史》", "《鸡鸣三省会议研究》"]
  },
  {
    "id": "evt-zhaxi-consolidation-1935-02-08",
    "type": "maneuver",
    "title": "扎西整编",
    "timestamp": "1935-02-08T08:00:00+08:00",
    "duration_hours": 36,
    "location": [105.05, 27.85],
    "participants": ["red-1st-army", "red-3rd-army", "red-5th-army", "red-9th-army"],
    "outcome": "red-advance",
    "description": "1935年2月8日,中央红军在扎西地区利用短暂休整进行整编,撤销师一级编制,把师的机关充实到团,各军团直辖团,全军团额由30万人缩编为约3.6万人。同时精简机关,充实连队,大大提高了部队的机动性和战斗力,为回师东进做了充分准备。",
    "sources": ["《红军长征史》", "《中国工农红军史料选辑》"]
  },
  {
    "id": "evt-second-crossing-east-1935-02-10",
    "type": "maneuver",
    "title": "回师东进",
    "timestamp": "1935-02-10T06:00:00+08:00",
    "duration_hours": 48,
    "location": [105.55, 27.95],
    "participants": ["red-1st-army", "red-3rd-army", "red-5th-army", "red-9th-army"],
    "outcome": "red-advance",
    "description": "1935年2月10日,根据扎西会议决定,中央红军主力突然由扎西地区掉头东进,出其不意地向敌人兵力薄弱的贵州境内回师,拉开了二渡赤水的序幕。国民党军在川南、滇东北部署的合围兵力被甩在身后,这一战略机动成为四渡赤水的神来之笔。",
    "sources": ["《红军长征史》", "《毛泽东军事文集》", "《中国工农红军长征全史》"]
  },
  {
    "id": "evt-gulin-battle-1935-02-15",
    "type": "battle",
    "title": "古蔺叙永地区战斗",
    "timestamp": "1935-02-15T08:00:00+08:00",
    "duration_hours": 72,
    "location": [105.80, 28.05],
    "participants": ["red-1st-army", "red-3rd-army", "red-5th-army", "blue-sichuan-liuxiang", "blue-chuan-army"],
    "outcome": "red-advance",
    "description": "1935年2月15日至17日,红军东进途中与川军在古蔺、叙永之间连续作战,红三军团参谋长邓萍在指挥前沿侦察时壮烈牺牲,是长征中我军牺牲的最高级别指挥员之一。红军各部击破川军阻击,顺利推进至赤水河畔。",
    "sources": ["《红军长征史》", "《彭德怀自述》"]
  },
  {
    "id": "evt-second-crossing-1935-02-18",
    "type": "crossing",
    "title": "二渡赤水",
    "timestamp": "1935-02-18T06:00:00+08:00",
    "duration_hours": 48,
    "location": [105.75, 27.85],
    "participants": ["red-1st-army", "red-3rd-army", "red-5th-army", "red-9th-army"],
    "outcome": "red-advance",
    "description": "1935年2月18日至21日,中央红军在太平渡、二郎滩等渡口二渡赤水河,重入贵州。红军利用敌人在贵州境内兵力空虚、黔军王家烈部战斗力不强、又没有坚固工事的有利条件,快速东进,完全打乱了敌人的合围部署,这是毛泽东指挥艺术的精彩之笔。",
    "sources": ["《红军长征史》", "《毛泽东军事文集》", "《四渡赤水》"]
  },
  {
    "id": "evt-tongzi-1935-02-24",
    "type": "battle",
    "title": "攻占桐梓",
    "timestamp": "1935-02-24T08:00:00+08:00",
    "duration_hours": 12,
    "location": [106.82, 28.15],
    "participants": ["red-1st-army", "red-3rd-army"],
    "outcome": "red-advance",
    "description": "1935年2月24日,红三军团奔袭桐梓县城,守敌黔军王家烈部一个团稍作抵抗即弃城而逃,红军顺利占领桐梓,打开了通往娄山关的大门,扫清了遵义北面的屏障。",
    "sources": ["《红军长征史》", "《彭德怀自述》"]
  },
  {
    "id": "evt-loushan-pass-1935-02-25",
    "type": "battle",
    "title": "血战娄山关",
    "timestamp": "1935-02-25T09:00:00+08:00",
    "duration_hours": 30,
    "location": [106.85, 28.05],
    "participants": ["red-1st-army", "red-3rd-army", "red-chuan-rear", "blue-guizhou"],
    "outcome": "red-advance",
    "casualties_red": 600,
    "casualties_blue": 2400,
    "description": "1935年2月25日,中央红军在娄山关及其以南地区对黔军王家烈部及中央军吴奇伟部发起进攻,红三军团主攻娄山关,红一军团从东侧迂回,经反复白刃格斗夺取制高点。'雄关漫道真如铁,而今迈步从头越'的词句即作于战后当晚。战斗全歼黔军王家烈部两个师大部,俘获甚多。",
    "sources": ["《红军长征史》", "《毛泽东诗词集》", "《彭德怀自述》", "《林彪军事文选》"]
  },
  {
    "id": "evt-zunyi-recapture-1935-02-28",
    "type": "battle",
    "title": "再克遵义",
    "timestamp": "1935-02-28T05:00:00+08:00",
    "duration_hours": 36,
    "location": [106.92, 27.72],
    "participants": ["red-1st-army", "red-3rd-army", "red-5th-army", "red-9th-army", "blue-center-xueyue", "blue-wuqiwei"],
    "outcome": "red-advance",
    "casualties_red": 1980,
    "casualties_blue": 3000,
    "description": "1935年2月28日凌晨,红三军团首先攻入遵义老城,红一军团随即攻入新城。中央军吴奇伟率两个师从乌江南岸驰援,在遵义城南的忠庄铺一带被红一、红三军团反包围,大部被歼,残部溃逃乌江,吴奇伟险些被俘,自请处分,蒋介石为之震怒。此役是中央红军长征以来取得的最大胜利,共歼灭和击溃敌军两个师又八个团,俘敌约3000人,缴枪2000余支。",
    "sources": ["《红军长征史》", "《中国工农红军长征全史》", "《吴奇伟传》"]
  },
  {
    "id": "evt-zunyi-occupied-1935-03-01",
    "type": "maneuver",
    "title": "遵义战役总结",
    "timestamp": "1935-03-01T10:00:00+08:00",
    "duration_hours": 24,
    "location": [106.92, 27.72],
    "participants": ["red-1st-army", "red-3rd-army", "red-5th-army", "red-9th-army", "person-mao-zedong", "person-zhou-enlai"],
    "outcome": "red-advance",
    "description": "1935年3月1日,红军占领遵义老城、新城及城南全部,军委在遵义老城召开团以上干部会议,毛泽东总结了遵义战役的胜利经验,指出这一胜利是'反攻的胜利',改变了红军自第五次反围剿以来的被动局面。同时全军进行了为期数日的休整补充。",
    "sources": ["《红军长征史》", "《毛泽东年谱》"]
  },
  {
    "id": "evt-gouba-meeting-1935-03-10",
    "type": "meeting",
    "title": "苟坝会议",
    "timestamp": "1935-03-10T14:00:00+08:00",
    "duration_hours": 36,
    "location": [106.78, 27.65],
    "participants": ["person-mao-zedong", "person-zhou-enlai", "person-zhangwentian", "person-wangjiaxiang", "person-zhude"],
    "outcome": "stalemate",
    "description": "1935年3月10日,中央政治局在贵州遵义县苟坝召开扩大会议,围绕是否进攻打鼓新场(今金沙县城)展开激烈争论。多数人主张进攻,毛泽东一人坚决反对,认为敌军已构成包围,贸然进攻将陷红军于绝境。会议最终取消进攻计划,并成立毛泽东、周恩来、王稼祥三人军事指挥小组,进一步巩固了毛泽东的军事指挥地位。",
    "sources": ["《中国共产党历史》第一卷", "《毛泽东年谱》", "《苟坝会议研究》"]
  },
  {
    "id": "evt-lubanchang-battle-1935-03-15",
    "type": "battle",
    "title": "鲁班场战斗",
    "timestamp": "1935-03-15T08:00:00+08:00",
    "duration_hours": 14,
    "location": [106.30, 27.75],
    "participants": ["red-1st-army", "red-3rd-army", "red-5th-army", "red-9th-army", "blue-zhouhunyuan", "blue-wuqiwei"],
    "outcome": "stalemate",
    "casualties_red": 1500,
    "casualties_blue": 1000,
    "description": "1935年3月15日,中央红军集中三个军团主力进攻驻守鲁班场的国民党中央军周浑元部,激战一日未能攻克,敌军增援逼近,红军伤亡约1500人,战至黄昏主动撤出战斗。鲁班场战斗未达预期目的,反而暴露了红军主力位置,促使毛泽东决定放弃在黔北建立根据地的设想,指挥红军三渡赤水。",
    "sources": ["《红军长征史》", "《林彪军事文选》", "《彭德怀自述》"]
  },
  {
    "id": "evt-third-crossing-1935-03-16",
    "type": "crossing",
    "title": "三渡赤水",
    "timestamp": "1935-03-16T18:00:00+08:00",
    "duration_hours": 24,
    "location": [106.10, 27.85],
    "participants": ["red-1st-army", "red-3rd-army", "red-5th-army", "red-9th-army"],
    "outcome": "red-advance",
    "description": "1935年3月16日傍晚至17日,中央红军主力在茅台镇附近三渡赤水河,佯装北渡长江的姿态,故意公开行军路线并制造渡河声势。蒋介石果然上当,急调川军、中央军、滇军向川南古蔺、叙永方向合围,企图围歼红军于川南,这就为红军后来秘密四渡赤水、南渡乌江创造了有利条件。",
    "sources": ["《红军长征史》", "《毛泽东军事文集》", "《四渡赤水》"]
  },
  {
    "id": "evt-fourth-crossing-1935-03-21",
    "type": "crossing",
    "title": "四渡赤水",
    "timestamp": "1935-03-21T20:00:00+08:00",
    "duration_hours": 48,
    "location": [106.05, 27.80],
    "participants": ["red-1st-army", "red-3rd-army", "red-5th-army"],
    "outcome": "red-advance",
    "description": "1935年3月21日晚至22日,中央红军主力在二郎滩、太平渡一带秘密折返四渡赤水,这是四渡赤水战役中最具决定性的一渡。担任伴动任务的红九军团在长干山、枫香坝地区伪装主力活动,成功将敌人主力吸引在川南古蔺一带,掩护红军主力秘密东返。这一步'出其不意'的妙棋,彻底打乱了蒋介石的合围部署。",
    "sources": ["《红军长征史》", "《毛泽东军事文集》", "《四渡赤水》"]
  },
  {
    "id": "evt-wujiang-pretend-1935-03-26",
    "type": "maneuver",
    "title": "佯攻贵阳",
    "timestamp": "1935-03-26T06:00:00+08:00",
    "duration_hours": 72,
    "location": [106.71, 26.58],
    "participants": ["red-1st-army", "red-3rd-army", "red-5th-army"],
    "outcome": "red-advance",
    "description": "1935年3月26日,中央红军主力南渡乌江后,先头部队突进到贵阳城下,故意大张旗鼓,做出攻打贵阳的姿态。蒋介石正在贵阳督战,惊恐之下急调滇军孙渡部入贵阳'保驾',而云南境内一时兵力空虚,为红军兵临昆明、直取金沙江埋下伏笔。",
    "sources": ["《红军长征史》", "《中国工农红军长征全史》", "《蒋介石日记》"]
  },
  {
    "id": "evt-kunming-feint-1935-04-02",
    "type": "maneuver",
    "title": "威逼昆明",
    "timestamp": "1935-04-02T08:00:00+08:00",
    "duration_hours": 72,
    "location": [102.71, 25.04],
    "participants": ["red-1st-army", "red-3rd-army", "red-5th-army", "red-9th-army"],
    "outcome": "red-advance",
    "description": "1935年4月2日,中央红军主力突然由贵州西部挺进云南,直逼云南省会昆明城下,沿途虚张声势,大造进攻昆明的舆论,目的是调动防守金沙江的敌军回援昆明。云南军阀龙云大为恐慌,急调各地民团及驻守金沙江的部队回援,这就为红军在绞平渡口从容渡江创造了千载难逢的良机。",
    "sources": ["《红军长征史》", "《中国工农红军长征全史》", "《龙云传》"]
  },
  {
    "id": "evt-huize-area-1935-04-06",
    "type": "maneuver",
    "title": "分兵入滇",
    "timestamp": "1935-04-06T08:00:00+08:00",
    "duration_hours": 96,
    "location": [103.30, 26.40],
    "participants": ["red-1st-army", "red-3rd-army", "red-5th-army", "red-9th-army"],
    "outcome": "red-advance",
    "description": "1935年4月6日,中央红军在云南曲靖、沾益一带集中后,兵分三路,经会泽、巧家、禄劝、武定等县向金沙江畔的绞平渡、龙街渡、洪门渡疾进。一路兼程,每天行军百里以上,抢在敌人反应过来之前抵达金沙江边。",
    "sources": ["《红军长征史》", "《中国工农红军长征全史》"]
  },
  {
    "id": "evt-jinsha-prep-1935-04-29",
    "type": "maneuver",
    "title": "抢占绞平渡",
    "timestamp": "1935-04-29T12:00:00+08:00",
    "duration_hours": 72,
    "location": [102.30, 26.10],
    "participants": ["red-1st-army", "person-liubocheng"],
    "outcome": "red-advance",
    "description": "1935年4月29日,中央红军干部团在总参谋长刘伯承指挥下,长途奔袭一百余里,一举抢占金沙江畔的绞平渡口,缴获敌船六只,控制了对岸渡船,并通过当地地下党和船工的支持,组织起37名船工日夜摆渡,拉开了巧渡金沙江的序幕。",
    "sources": ["《红军长征史》", "《刘伯承传》", "《中国共产党历史》第一卷"]
  },
  {
    "id": "evt-jinsha-crossing-1935-05-03",
    "type": "crossing",
    "title": "巧渡金沙江",
    "timestamp": "1935-05-03T08:00:00+08:00",
    "duration_hours": 168,
    "location": [102.30, 26.10],
    "participants": ["red-1st-army", "red-3rd-army", "red-5th-army", "red-9th-army", "person-zhude", "person-liubocheng"],
    "outcome": "red-advance",
    "description": "1935年5月3日至9日,中央红军主力在绞平渡口利用缴获的6只木船和37名船工,昼夜不停地连续摆渡七天七夜。毛泽东、朱德、刘伯承在现场指挥,工兵在急流上架设浮桥辅助渡江。由于渡口选取得当,加上地下党的周密组织,3万余红军主力及大量物资、骡马安全渡过金沙江,完全跳出了数十万国民党军的围追堵截,取得了战略转移中具有决定意义的胜利。",
    "sources": ["《红军长征史》", "《朱德传》", "《刘伯承传》", "《中国共产党的九十年》"]
  },
  {
    "id": "evt-huili-meeting-1935-05-12",
    "type": "meeting",
    "title": "会理会议",
    "timestamp": "1935-05-12T10:00:00+08:00",
    "duration_hours": 24,
    "location": [102.25, 26.65],
    "participants": ["person-mao-zedong", "person-zhou-enlai", "person-zhangwentian", "person-chenyun", "person-bogu", "person-zhude"],
    "outcome": "red-advance",
    "description": "1935年5月12日,中央政治局在四川会理县城郊召开扩大会议,会议肯定了四渡赤水以来毛泽东的军事指挥,批评了林彪对毛泽东军事指挥的怀疑,统一了党内对遵义会议以来军事路线的认识。会议也讨论了会师红四方面军的前景,要求警惕张国焘可能的分裂倾向。",
    "sources": ["《中国共产党历史》第一卷", "《毛泽东年谱》", "《朱德年谱》"]
  },
  {
    "id": "evt-campaign-end-1935-05-09",
    "type": "maneuver",
    "title": "渡过金沙江,完成战略转移",
